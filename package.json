{
  "name": "update-electron-app",
  "version": "0.0.0-development",
  "description": "A drop-in module that adds autoUpdating capabilities to Electron apps",
  "repository": "https://github.com/electron/update-electron-app",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "publishConfig": {
    "provenance": true
  },
  "dependencies": {
    "github-url-to-object": "^4.0.4",
    "ms": "^2.1.1"
  },
  "devDependencies": {
    "@types/github-url-to-object": "^4.0.4",
    "@types/jest": "^29.5.14",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.1",
    "electron": "^39.8.4",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint && oxfmt --check .",
    "prepack": "yarn build",
    "prepare": "husky",
    "test": "jest",
    "watch": "jest --watch --notify --notifyMode=change --coverage"
  },
  "lint-staged": {
    "*.{js,ts,cjs,cts,mjs,mts}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "resolutions": {
    "fsevents": "npm:@electron/fsevents@2.3.3-fork"
  },
  "packageManager": "yarn@4.14.1"
}
